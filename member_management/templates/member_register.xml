<odoo>
    <template id="member_register_template" name="Member Registration">
        <t t-call="website.layout">
            <div class="container my-5">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="card shadow-sm">
                            <div class="card-body p-4">
                                <h3 class="mb-4">Member Registration</h3>

                                <t t-if="error">
                                    <div class="alert alert-danger" role="alert">
                                        <t t-esc="error"/>
                                    </div>
                                </t>
                                <t t-if="success">
                                    <div class="alert alert-success" role="alert">
                                        <t t-esc="success"/>
                                    </div>
                                </t>

                                <form action="/member/register" method="post"
                                      enctype="multipart/form-data" class="needs-validation">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Name *</label>
                                            <input type="text" name="name" class="form-control"
                                                   t-att-value="values.get('name','')" required="required"/>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">DOB</label>
                                            <input type="date" name="dob" class="form-control"
                                                   t-att-value="values.get('dob','')"/>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Email *</label>
                                            <input type="email" name="email" class="form-control"
                                                   t-att-value="values.get('email','')" required="required"/>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Phone</label>
                                            <input type="text" name="phone" class="form-control"
                                                   t-att-value="values.get('phone','')"/>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Member Type *</label>
                                            <select name="member_type" class="form-select" required="required">
                                                <option value="">Select...</option>
                                                <option value="supplier" t-att-selected="values.get('member_type')=='supplier'">Supplier</option>
                                                <option value="partner" t-att-selected="values.get('member_type')=='partner'">Partner</option>
                                                <option value="member" t-att-selected="values.get('member_type')=='member'">Member</option>
                                            </select>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Profile Photo *</label>
                                            <input type="file" name="profile_image" class="form-control"
                                                   accept="image/*" required="required"/>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Password *</label>
                                            <input type="password" name="password" class="form-control" required="required"/>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Confirm Password *</label>
                                            <input type="password" name="confirm_password" class="form-control" required="required"/>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Gender</label>
                                            <select name="gender" class="form-select">
                                                <option value="">Select...</option>
                                                <option value="male" t-att-selected="values.get('gender')=='male'">Male</option>
                                                <option value="female" t-att-selected="values.get('gender')=='female'">Female</option>
                                                <option value="other" t-att-selected="values.get('gender')=='other'">Other</option>
                                            </select>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Marital Status</label>
                                            <select name="marital_status" class="form-select">
                                                <option value="">Select...</option>
                                                <option value="single" t-att-selected="values.get('marital_status')=='single'">Single</option>
                                                <option value="married" t-att-selected="values.get('marital_status')=='married'">Married</option>
                                                <option value="divorced" t-att-selected="values.get('marital_status')=='divorced'">Divorced</option>
                                                <option value="widowed" t-att-selected="values.get('marital_status')=='widowed'">Widowed</option>
                                            </select>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">City</label>
                                            <input type="text" name="city" class="form-control"
                                                   t-att-value="values.get('city','')"/>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Country</label>
                                            <select name="country_id" class="form-select">
                                                <option value="">Select...</option>
                                                <t t-foreach="countries" t-as="c">
                                                    <option t-att-value="c.id"
                                                            t-att-selected="str(values.get('country_id',''))==str(c.id)">
                                                        <t t-esc="c.name"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>

                                        <div class="col-12">
                                            <label class="form-label">Address</label>
                                            <textarea name="street" class="form-control" rows="3"><t t-esc="values.get('street','')"/></textarea>
                                        </div>

                                        <div class="col-12 mt-2">
                                            <button type="submit" class="btn btn-primary w-100">Submit</button>
                                        </div>
                                    </div>

                                </form>

                            </div>
                        </div>

                        <p class="text-muted mt-3 small">
                            Your registration will be reviewed. If accepted, you can log in using your email and password.
                        </p>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
