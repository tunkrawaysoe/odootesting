<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Property List View -->
    <record id="view_estate_property_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list
                decoration-success="state=='offer_received'"
                decoration-info="state=='offer_accepted'"
                decoration-muted="state=='sold'">
                <field name="name" />
                <field name="property_type_id" />
                <field name="tag_ids" widget="many2many_tags" />
                <field name="expected_price" />
                <field name="best_price" />
                <field name="selling_price" />
                <field name="bedrooms" />
                <field name="total_area" />
                <field name="date_availability" />
                <field name="state" />
                <field name="buyer_id"
                    invisible="state != 'sold'"
                    readonly="1" />
            </list>
        </field>
    </record>

    <!-- Property Form View -->
    <record id="view_estate_property_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form>

                <!-- Header Buttons -->
                <header>
                    <button name="action_sold"
                        type="object"
                        string="Mark as Sold"
                        class="btn-primary"
                        invisible="state in ('sold','canceled')" />
                    <button name="action_cancel"
                        type="object"
                        string="Cancel"
                        class="btn-secondary"
                        invisible="state in ('sold','canceled')" />
                    <field name="state"
                        widget="statusbar"
                        statusbar_visible="new,offer_received,offer_accepted,sold" />
                </header>

                <sheet>
                    <!-- Main Property Fields Outside Notebook -->
                    <group>
                        <field name="name" placeholder="Property Name" />
                        <field name="description" />
                        <field name="postcode" />
                        <field name="date_availability" />
                        <field name="expected_price" />
                        <field name="selling_price" />
                        <field name="best_price" />
                        <field name="bedrooms" />
                        <field name="living_area" />
                        <field name="total_area" />
                        <field name="seller_id" />
                        <field name="buyer_id"
                            invisible="state != 'sold'"
                            readonly="1" />
                        <field name="property_type_id" />
                        <field name="tag_ids" widget="many2many_tags" />
                    </group>

                    <!-- Notebook with Features and Offers -->
                    <notebook>

                        <!-- Features Tab -->
                        <page string="Features">
                            <group>
                                <field name="facades" />
                                <field name="garage" />
                                <field name="garden" />
                                <field name="garden_area" />
                                <field name="garden_orientation" />
                            </group>
                        </page>

                        <!-- Offers Tab -->
                        <page string="Offers">
                            <field name="offer_ids">
                                <list editable="bottom"
                                    decoration-danger="status=='refused'"
                                    decoration-success="status=='accepted'">
                                    <field name="price" />
                                    <field name="partner_id" />
                                    <field name="validity" />
                                    <field name="date_deadline" />
                                    <field name="status" />
                                    <button name="action_accept" type="object" string="Accept"
                                        class="oe_highlight"
                                        invisible="status != 'pending'" />
                                    <button name="action_refuse" type="object" string="Refuse"
                                        class="oe_stat_button"
                                        invisible="status != 'pending'" />
                                </list>
                            </field>
                        </page>

                    </notebook>
                </sheet>

            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_estate_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>