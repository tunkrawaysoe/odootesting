<odoo>
    <record id="seq_bss_attendance" model="ir.sequence">
        <field name="name">Attendance Sequence</field>
        <field name="code">bss.attendance.sequence</field>
        <field name="prefix">ATD/%(year)s/%(month)s/</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
    </record>
</odoo>
