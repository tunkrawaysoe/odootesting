<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- Employee: only own requests -->
    <record id="rule_asset_request_employee" model="ir.rule">
      <field name="name">Asset Request: Employee Own Access</field>
      <field name="model_id" ref="model_employee_asset_request"/>
      <field name="groups" eval="[(4, ref('employee_asset_request.group_asset_employee'))]"/>
      <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
    </record>

    <!-- Manager: only requests where I am the manager -->
    <record id="rule_asset_request_manager" model="ir.rule">
      <field name="name">Asset Request: Manager Own Team</field>
      <field name="model_id" ref="model_employee_asset_request"/>
      <field name="groups" eval="[(4, ref('employee_asset_request.group_asset_manager'))]"/>
      <field name="domain_force">[('manager_id.user_id', '=', user.id)]</field>
    </record>

  </data>
</odoo>