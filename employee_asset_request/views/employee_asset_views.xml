<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_employee_asset_list" model="ir.ui.view">
            <field name="name">employee.asset.list</field>
            <field name="model">employee.asset</field>
            <field name="arch" type="xml">
                <list string="Assets">
                    <field name="name"/>
                    <field name="serial_number"/>
                    <field name="asset_type"/>
                    <field name="state"/>
                    <field name="assigned_employee_id"/>
                </list>
            </field>
        </record>
        <record id="view_employee_asset_form" model="ir.ui.view">
            <field name="name">employee.asset.form</field>
            <field name="model">employee.asset</field>
            <field name="arch" type="xml">
                <form string="Asset">
                    <sheet>
                        <group string="Asset Information">
                            <field name="name"/>
                            <field name="serial_number"/>
                            <field name="asset_type"/>
                        </group>
                        <group string="Assignment" colspan="2">
                            <field name="state" readonly="1"/>
                            <field name="assigned_employee_id" readonly="1"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>
        <record id="action_employee_asset" model="ir.actions.act_window">
            <field name="name">Assets</field>
            <field name="res_model">employee.asset</field>
            <field name="view_mode">list,form</field>
        </record>
  </data>
</odoo>
