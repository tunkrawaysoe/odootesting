<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>
    <record id="view_asset_assignment_wizard_form" model="ir.ui.view">
                <field name="name">asset.assignment.wizard.form</field>
                <field name="model">asset.assignment.wizard</field>
                <field name="arch" type="xml">
                    <form string="Asset Assignment">
                        <sheet>
                            <!-- Request Info -->
                            <group string="Request Information">
                                <field name="request_id" readonly="1"/>
                                <field name="employee_id" readonly="1"/>
                                <field name="asset_type" readonly="1"/>
                                <field name="quantity" readonly="1"/>
                            </group>
                            <!-- Warning if no available assets -->
                            <group string="Available Assets">
                                <field name="no_assets_message" readonly="1"
                                       style="color:red; font-weight:bold;"/>
                                <field name="asset_ids" widget="many2many_tags"
                                       options="{'no_create': True}"/>
                            </group>
                        </sheet>
                        <!-- Wizard Buttons -->
                        <footer>
                            <button name="action_confirm_assignment"
                                    type="object"
                                    string="Confirm Assignment"
                                    class="btn-primary"/>
                            <button string="Cancel"
                                    special="cancel"
                                    class="btn-secondary"/>
                        </footer>
                    </form>
                </field>
            </record>
  </data>
</odoo>
