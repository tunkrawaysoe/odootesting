<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Properties: Estate User can only see their own properties -->
    <record id="estate_property_own_rule" model="ir.rule">
        <field name="name">Estate Properties: read all</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('real_estate.group_estate_user'))]"/>
    </record>

    <!-- Offers: Estate User can only see offers for their own properties -->
    <record id="estate_offer_own_property_rule" model="ir.rule">
        <field name="name">Estate Offers: offers for my properties only</field>
        <field name="model_id" ref="model_estate_property_offer"/>
        <field name="domain_force">[('property_id.seller_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('real_estate.group_estate_user'))]"/>
    </record>

</odoo>