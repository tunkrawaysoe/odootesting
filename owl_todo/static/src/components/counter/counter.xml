<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="owl_todo.Counter">
        <div class="counter-box border p-4 mt-4 text-center bg-white rounded shadow-sm mx-auto" style="max-width: 500px;">
            <h5 class="mb-4">Multi-Counter</h5>
            
            <div class="d-flex justify-content-center align-items-center gap-4 mb-4">
                <div class="p-2 border rounded bg-light">
                    <small class="text-muted d-block mb-1">Counter 1</small>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-outline-danger" t-on-click="this.dec1">-</button>
                        <strong class="fs-4"><t t-esc="state.counter1"/></strong>
                        <button class="btn btn-sm btn-outline-success" t-on-click="this.inc1">+</button>
                    </div>
                </div>

                <div class="p-2 border rounded bg-light">
                    <small class="text-muted d-block mb-1">Counter 2</small>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-sm btn-outline-danger" t-on-click="this.dec2">-</button>
                        <strong class="fs-4"><t t-esc="state.counter2"/></strong>
                        <button class="btn btn-sm btn-outline-success" t-on-click="this.inc2">+</button>
                    </div>
                </div>
            </div>

            <hr/>

            <div class="mt-3">
                <span class="text-muted small d-block">GRAND TOTAL</span>
                <h2 class="fw-bold text-primary">
                    <t t-esc="state.counter1 + state.counter2"/>
                </h2>
            </div>
        </div>
    </t>
</templates>