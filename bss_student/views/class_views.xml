<odoo>
    <data>
        <!-- Class Form View -->
        <record id="view_bss_class_form" model="ir.ui.view">
            <field name="name">bss.class.form</field>
            <field name="model">bss.class</field>
            <field name="arch" type="xml">
                <form string="Class">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="subject_ids" widget="many2many_tags"/>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Class Tree View -->
        <record id="view_bss_class_tree" model="ir.ui.view">
            <field name="name">bss.class.list</field>
            <field name="model">bss.class</field>
            <field name="arch" type="xml">
                <list string="Classes">
                    <field name="name"/>
                    <field name="code"/>
                </list>
            </field>
        </record>



    </data>
</odoo>